{
  "title_max_length": {
    "description": "标题最大长度",
    "type": "int",
    "default": 60
  },
  "description_max_length": {
    "description": "描述最大长度",
    "type": "int",
    "default": 200
  },
  "max_items_per_poll": {
    "description": "每次轮询最大条目数",
    "type": "int",
    "default": 5
  },
  "t2i": {
    "description": "是否使用文字转图片",
    "type": "bool",
    "default": false
  },
  "is_hide_url": {
    "description": "是否隐藏链接",
    "type": "bool",
    "default": false
  },
  "is_read_pic": {
    "description": "是否读取图片",
    "type": "bool",
    "default": true
  },
  "is_adjust_pic": {
    "description": "图片防和谐",
    "type": "bool",
    "default": false
  },
  "max_pic_item": {
    "description": "最大图片数(-1不限)",
    "type": "int",
    "default": 3
  },
  "compose": {
    "description": "QQ平台合并转发",
    "type": "bool",
    "default": true
  },
  "enable_comment": {
    "description": "是否开启AI锐评（推送时bot用人设评论动态内容）",
    "type": "bool",
    "default": true
  },
  "comment_provider_id": {
    "description": "锐评用的LLM提供商（留空则用默认）",
    "type": "string",
    "default": "",
    "_special": "select_provider"
  },
  "comment_persona": {
    "description": "锐评用的人格（留空则用默认人格）",
    "type": "string",
    "default": "",
    "_special": "select_persona"
  },
  "comment_max_length": {
    "description": "锐评最大字数",
    "type": "int",
    "default": 80
  },
  "bot_qq": {
    "description": "Bot的QQ号（用于显示头像）",
    "type": "string",
    "default": ""
  },
  "bot_provider_name": {
    "description": "Bot使用的服务商名称（显示在锐评旁边）",
    "type": "string",
    "default": ""
  },
  "content_filter": {
    "description": "是否过滤不适合推送的内容（反动/暴力/涩情等）",
    "type": "bool",
    "default": true
  },
  "filter_provider_id": {
    "description": "内容过滤用的LLM（建议选便宜快速的）",
    "type": "string",
    "default": "",
    "_special": "select_provider"
  },
  "image_caption_provider_id": {
    "description": "识图用的LLM（如gemini）",
    "type": "string",
    "default": "",
    "_special": "select_provider"
  },
  "global_feeds": {
    "description": "全局订阅源（推给所有活跃群），每行一个RSSHub路由，如 /twitter/user/elonmusk",
    "type": "text",
    "default": ""
  },
  "global_feed_interval": {
    "description": "全局订阅基础检查间隔（分钟）",
    "type": "int",
    "default": 15
  },
  "global_feed_max_interval": {
    "description": "全局订阅最大检查间隔（分钟），退避上限",
    "type": "int",
    "default": 1440
  },
  "push_delay_min": {
    "description": "推送间隔最小秒数（防风控）",
    "type": "float",
    "default": 5.0
  },
  "push_delay_max": {
    "description": "推送间隔最大秒数（防风控）",
    "type": "float",
    "default": 8.0
  },
  "safe_mode": {
    "description": "安全模式：开启后全局推送只发到测试群，不发其他群",
    "type": "bool",
    "default": true
  },
  "safe_mode_groups": {
    "description": "安全模式测试群号（多个用逗号分隔，如 123456,789012）",
    "type": "string",
    "default": ""
  },
  "group_cooldown_minutes": {
    "description": "全局推送冷却期（分钟）：同一个群在此时间内最多收到一次全局推送",
    "type": "int",
    "default": 60
  },
  "browserless_url": {
    "description": "Browserless 截图服务地址（Docker容器名:端口）",
    "type": "string",
    "default": "http://browserless:3000"
  }
}
